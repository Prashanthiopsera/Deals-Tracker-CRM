# Exclude local Terraform working directories and sensitive state files.
# .terraform.lock.hcl IS committed — it pins provider versions for reproducible applies.

# Terraform working directory (downloaded providers and modules)
**/.terraform/

# State files — stored remotely in S3; never commit local state
*.tfstate
*.tfstate.backup

# Variable files with real values — use .tfvars.example for documentation
*.tfvars
!*.tfvars.example

# Generated plan files
*.tfplan

# Crash log files
crash.log
crash.*.log

# Terraform CLI configuration
.terraformrc
terraform.rc
