# Example variable values for the Aurora module.
# Consumed by environment root modules — not applied directly.

project_name = "p7vc-crm"
environment  = "dev"

# Populated from the VPC module outputs at apply time:
# vpc_id               = "vpc-xxxxxxxx"
# isolated_subnet_ids  = ["subnet-aaa", "subnet-bbb"]
# private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]
# private_subnet_ids   = ["subnet-ccc", "subnet-ddd"]

engine_version  = "16.4"
database_name   = "p7vc_crm"
master_username = "p7vc_admin"

backup_retention_period = 35
preferred_backup_window = "03:00-04:00"

serverless_min_capacity = 0.5
serverless_max_capacity = 16

monitoring_interval                   = 60
performance_insights_retention_period = 7
secret_rotation_days                  = 30

deletion_protection = true

common_tags = {
  Project     = "p7vc-crm"
  ManagedBy   = "terraform"
  Environment = "dev"
}
